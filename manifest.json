{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDes__",
  "version": "2.1.1",
  "default_locale": "es",
  "action": {
    "default_title": "__MSG_extName__",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "downloads", "tabs", "scripting", "activeTab", "offscreen"],
  "host_permissions": [
    "https://*.vimeo.com/*",
    "https://player.vimeo.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://player.vimeo.com/*", "https://vimeo.com/*"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
