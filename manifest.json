{
  "manifest_version": 3,
  "name": "Vimeo Owned Video Downloader",
  "version": "6.0.0",
  "description": "Descarga videos propios embebidos desde Vimeo interceptando la carga del player.",
  "permissions": ["activeTab", "scripting", "downloads", "storage", "tabs"],
  "host_permissions": [
    "https://player.vimeo.com/*",
    "https://*.vimeo.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_title": "Vimeo Downloader",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["page_scanner.js"],
      "run_at": "document_idle",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": ["https://player.vimeo.com/*"],
      "js": ["vimeo_interceptor.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}
