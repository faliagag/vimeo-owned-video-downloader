{
  "manifest_version": 3,
  "name": "Vimeo Video Downloader",
  "version": "2.0.0",
  "description": "Descarga videos de Vimeo con detección automática de calidades",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Vimeo Downloader"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "*://*.vimeo.com/*",
    "*://*.vimeocdn.com/*"
  ],
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.vimeo.com/*",
        "*://*/*"
      ],
      "js": ["js/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["js/inject.js"],
      "matches": ["*://*.vimeo.com/*", "*://*/*"]
    }
  ]
}
