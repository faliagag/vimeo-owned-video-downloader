{
  "manifest_version": 3,
  "name": "Vimeo Owned Video Downloader",
  "version": "9.2.0",
  "description": "Descarga tus videos Vimeo embebidos en MP4. Usa cookies de sesión Vimeo automáticamente.",
  "permissions": ["activeTab", "scripting", "downloads", "storage", "tabs", "cookies"],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src https://* http://*; script-src 'self';"
  },
  "action": {
    "default_title": "Vimeo Downloader",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [{
    "resources": ["downloader.html", "downloader.js", "floater.js", "floater.css"],
    "matches": ["<all_urls>"]
  }],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["page_scanner.js"],
      "run_at": "document_idle",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": ["https://player.vimeo.com/*", "http://player.vimeo.com/*"],
      "js": ["vimeo_interceptor.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}
