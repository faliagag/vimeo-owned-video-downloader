{
  "manifest_version": 3,
  "name": "Vimeo Owned Video Downloader",
  "version": "6.4.0",
  "description": "Descarga y convierte videos propios embebidos desde Vimeo. Convierte HLS a MP4 directamente en el navegador.",
  "permissions": ["activeTab", "scripting", "downloads", "storage", "tabs", "offscreen"],
  "host_permissions": [
    "https://player.vimeo.com/*",
    "https://*.vimeo.com/*",
    "https://*.vimeocdn.com/*",
    "https://skyfire.vimeocdn.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_title": "Vimeo Downloader",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["page_scanner.js"],
      "run_at": "document_idle",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": ["https://player.vimeo.com/*"],
      "js": ["vimeo_interceptor.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
